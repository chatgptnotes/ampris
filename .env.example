# Database
DATABASE_URL=postgresql://gridvision:gridvision_pass@localhost:5432/gridvision_scada
TIMESCALE_URL=postgresql://gridvision:gridvision_pass@localhost:5433/gridvision_timescale

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Server
SERVER_PORT=3001
NODE_ENV=development

# Frontend
VITE_API_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:3001

# CORS
CORS_ORIGIN=http://localhost:5173

# Bcrypt
BCRYPT_SALT_ROUNDS=12

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=5

# OpenAI Vision API (for SLD generation)
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o
SLD_GENERATION_MAX_FILE_SIZE_MB=20

# Anthropic API (for SLD generation & content generation)
ANTHROPIC_API_KEY=sk-ant-...

# Gemini AI API (for infographic image generation)
GEMINI_API_KEY=your-gemini-api-key
