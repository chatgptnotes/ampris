generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Substations ───────────────────────────────────

model Substation {
  id              String    @id @default(uuid()) @db.Uuid
  name            String    @db.VarChar(100)
  code            String    @unique @db.VarChar(20)
  type            String    @db.VarChar(20) // '33/11kV' | '132/33kV'
  location        String?   @db.VarChar(200)
  latitude        Decimal?  @db.Decimal(10, 7)
  longitude       Decimal?  @db.Decimal(10, 7)
  commissionedAt  DateTime? @map("commissioned_at") @db.Date
  status          String    @default("ACTIVE") @db.VarChar(20)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  voltageLevels   VoltageLevel[]
  iedConnections  IedConnection[]

  @@map("substations")
}

model VoltageLevel {
  id              String    @id @default(uuid()) @db.Uuid
  substationId    String    @map("substation_id") @db.Uuid
  nominalKv       Decimal   @map("nominal_kv") @db.Decimal(6, 1)
  levelType       String    @map("level_type") @db.VarChar(10) // 'HV' | 'LV' | 'TV'
  busConfig       String    @default("SINGLE_BUS") @map("bus_config") @db.VarChar(30)

  substation      Substation @relation(fields: [substationId], references: [id])
  bays            Bay[]

  @@map("voltage_levels")
}

model Bay {
  id              String    @id @default(uuid()) @db.Uuid
  voltageLevelId  String    @map("voltage_level_id") @db.Uuid
  name            String    @db.VarChar(50)
  bayType         String    @map("bay_type") @db.VarChar(20)
  bayNumber       Int?      @map("bay_number")
  status          String    @default("ACTIVE") @db.VarChar(20)

  voltageLevel    VoltageLevel @relation(fields: [voltageLevelId], references: [id])
  equipment       Equipment[]

  @@map("bays")
}

model Equipment {
  id              String    @id @default(uuid()) @db.Uuid
  bayId           String    @map("bay_id") @db.Uuid
  type            String    @db.VarChar(30)
  tag             String    @unique @db.VarChar(80)
  name            String    @db.VarChar(100)
  ratedVoltage    Decimal?  @map("rated_voltage") @db.Decimal(8, 2)
  ratedCurrent    Decimal?  @map("rated_current") @db.Decimal(8, 2)
  ratedMva        Decimal?  @map("rated_mva") @db.Decimal(8, 2)
  sldX            Int       @default(0) @map("sld_x")
  sldY            Int       @default(0) @map("sld_y")
  sldRotation     Int       @default(0) @map("sld_rotation")
  metadata        Json      @default("{}") @db.JsonB

  bay             Bay       @relation(fields: [bayId], references: [id])
  dataPoints      DataPoint[]
  controlCommands ControlCommand[]

  @@map("equipment")
}

model DataPoint {
  id              String    @id @default(uuid()) @db.Uuid
  equipmentId     String    @map("equipment_id") @db.Uuid
  tag             String    @unique @db.VarChar(100)
  name            String    @db.VarChar(150)
  paramType       String    @map("param_type") @db.VarChar(10) // 'ANALOG' | 'DIGITAL' | 'COUNTER'
  unit            String?   @db.VarChar(20)
  minValue        Decimal?  @map("min_value") @db.Decimal(12, 4)
  maxValue        Decimal?  @map("max_value") @db.Decimal(12, 4)
  deadband        Decimal   @default(0) @db.Decimal(8, 4)
  iedConnectionId String?   @map("ied_connection_id") @db.Uuid
  registerAddress Int?      @map("register_address")
  registerType    String?   @map("register_type") @db.VarChar(20)
  scaleFactor     Decimal   @default(1.0) @map("scale_factor") @db.Decimal(10, 6)
  offsetValue     Decimal   @default(0) @map("offset_value") @db.Decimal(10, 4)

  equipment       Equipment @relation(fields: [equipmentId], references: [id])
  iedConnection   IedConnection? @relation(fields: [iedConnectionId], references: [id])
  alarmDefinitions AlarmDefinition[]

  @@map("data_points")
}

model IedConnection {
  id              String    @id @default(uuid()) @db.Uuid
  substationId    String    @map("substation_id") @db.Uuid
  name            String    @db.VarChar(100)
  protocol        String    @db.VarChar(20) // 'MODBUS_TCP' | 'DNP3' | 'IEC61850'
  ipAddress       String    @map("ip_address") @db.VarChar(45)
  port            Int
  slaveId         Int?      @map("slave_id")
  pollingIntervalMs Int     @default(1000) @map("polling_interval_ms")
  timeoutMs       Int       @default(5000) @map("timeout_ms")
  status          String    @default("ACTIVE") @db.VarChar(20)

  substation      Substation @relation(fields: [substationId], references: [id])
  dataPoints      DataPoint[]

  @@map("ied_connections")
}

// ─── Users & Auth ──────────────────────────────────

model User {
  id              String    @id @default(uuid()) @db.Uuid
  username        String    @unique @db.VarChar(50)
  passwordHash    String    @map("password_hash") @db.VarChar(255)
  name            String    @db.VarChar(100)
  email           String?   @db.VarChar(100)
  role            String    @db.VarChar(20) // 'ADMIN' | 'ENGINEER' | 'OPERATOR' | 'VIEWER'
  isActive        Boolean   @default(true) @map("is_active")
  lastLogin       DateTime? @map("last_login") @db.Timestamptz()
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  sessions            Session[]
  alarmAcks           AlarmLog[] @relation("alarm_acked_by")
  controlCommands     ControlCommand[]
  auditTrail          AuditTrail[]
  projects            Project[]
  projectMemberships  ProjectMember[]

  @@map("users")
}

model Session {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  tokenHash       String    @map("token_hash") @db.VarChar(255)
  ipAddress       String?   @map("ip_address") @db.VarChar(45)
  userAgent       String?   @map("user_agent")
  expiresAt       DateTime  @map("expires_at") @db.Timestamptz()
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  user            User      @relation(fields: [userId], references: [id])

  @@map("sessions")
}

// ─── Alarms ────────────────────────────────────────

model AlarmDefinition {
  id              String    @id @default(uuid()) @db.Uuid
  dataPointId     String    @map("data_point_id") @db.Uuid
  alarmType       String    @map("alarm_type") @db.VarChar(20)
  threshold       Decimal?  @db.Decimal(12, 4)
  priority        Int       @db.SmallInt
  messageTemplate String    @map("message_template") @db.VarChar(200)
  deadband        Decimal   @default(0) @db.Decimal(8, 4)
  delayMs         Int       @default(0) @map("delay_ms")
  isEnabled       Boolean   @default(true) @map("is_enabled")

  dataPoint       DataPoint @relation(fields: [dataPointId], references: [id])
  alarmLogs       AlarmLog[]

  @@map("alarm_definitions")
}

model AlarmLog {
  id              String    @id @default(uuid()) @db.Uuid
  alarmDefId      String    @map("alarm_def_id") @db.Uuid
  raisedAt        DateTime  @default(now()) @map("raised_at") @db.Timestamptz()
  clearedAt       DateTime? @map("cleared_at") @db.Timestamptz()
  ackedAt         DateTime? @map("acked_at") @db.Timestamptz()
  ackedBy         String?   @map("acked_by") @db.Uuid
  shelvedUntil    DateTime? @map("shelved_until") @db.Timestamptz()
  valueAtRaise    Float?    @map("value_at_raise")
  priority        Int       @db.SmallInt
  message         String    @db.VarChar(300)

  alarmDef        AlarmDefinition @relation(fields: [alarmDefId], references: [id])
  ackedByUser     User?     @relation("alarm_acked_by", fields: [ackedBy], references: [id])

  @@map("alarm_log")
}

// ─── Projects & Mimic Pages ──────────────────────────

model Project {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(200)
  description String?  @db.Text
  ownerId     String   @map("owner_id") @db.Uuid
  status      String   @default("ACTIVE") @db.VarChar(20)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  owner           User     @relation(fields: [ownerId], references: [id])
  mimicPages      MimicPage[]
  members         ProjectMember[]
  tags            Tag[]
  tagScripts      TagScript[]
  testScenarios   TestScenario[]
  externalDevices ExternalDevice[]
  recipes         Recipe[]
  reportTemplates ReportTemplate[]
  generatedReports GeneratedReport[]
  commandSequences CommandSequence[]
  interlocks       Interlock[]
  sboConfigs       SBOConfig[]
  operatorAuthorities OperatorAuthority[]

  @@map("projects")
}

model MimicPage {
  id              String   @id @default(uuid()) @db.Uuid
  projectId       String   @map("project_id") @db.Uuid
  name            String   @db.VarChar(100)
  pageOrder       Int      @default(0) @map("page_order")
  width           Int      @default(1920)
  height          Int      @default(1080)
  backgroundColor String   @default("#FFFFFF") @map("background_color") @db.VarChar(20)
  gridSize        Int      @default(20) @map("grid_size")
  elements        Json     @default("[]")
  connections     Json     @default("[]")
  isHomePage      Boolean  @default(false) @map("is_home_page")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("mimic_pages")
}

model ProjectMember {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  role      String   @default("VIEWER") @db.VarChar(20)
  assignedAt DateTime @default(now()) @map("assigned_at") @db.Timestamptz()

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_members")
}

// ─── External Devices ─────────────────────────────

model ExternalDevice {
  id              String    @id @default(uuid()) @db.Uuid
  name            String    @db.VarChar(200)
  description     String?   @db.Text
  protocol        String    @db.VarChar(20) // MODBUS_RTU, MODBUS_TCP, OPC_UA, DNP3, IEC61850
  enabled         Boolean   @default(true)
  // TCP / common
  host            String?   @db.VarChar(200)
  port            Int?
  slaveId         Int?      @map("slave_id")
  // RTU serial
  serialPort      String?   @map("serial_port") @db.VarChar(100)
  baudRate        Int?      @map("baud_rate")
  dataBits        Int?      @map("data_bits")
  stopBits        Int?      @map("stop_bits")
  parity          String?   @db.VarChar(10) // NONE, EVEN, ODD
  // OPC UA
  endpointUrl     String?   @map("endpoint_url") @db.VarChar(500)
  securityMode    String?   @map("security_mode") @db.VarChar(30) // None, Sign, SignAndEncrypt
  securityPolicy  String?   @map("security_policy") @db.VarChar(50)
  username        String?   @db.VarChar(100)
  password        String?   @db.VarChar(200)
  // Polling
  pollIntervalMs  Int       @default(1000) @map("poll_interval_ms")
  timeoutMs       Int       @default(5000) @map("timeout_ms")
  retryCount      Int       @default(3) @map("retry_count")
  // Status
  status          String    @default("DISCONNECTED") @db.VarChar(20) // CONNECTED, DISCONNECTED, ERROR
  lastError       String?   @map("last_error") @db.Text
  lastConnectedAt DateTime? @map("last_connected_at") @db.Timestamptz()
  // Project
  projectId       String    @map("project_id") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tags            Tag[]

  @@map("external_devices")
}

// ─── Tags & Testing ───────────────────────────────

model Tag {
  id            String   @id @default(uuid()) @db.Uuid
  name          String   @db.VarChar(200)
  description   String?  @db.Text
  type          String   @db.VarChar(20) // INTERNAL, SIMULATED, CALCULATED, EXTERNAL
  dataType      String   @map("data_type") @db.VarChar(20) // BOOLEAN, INTEGER, FLOAT, STRING
  unit          String?  @db.VarChar(30)
  minValue      Float?   @map("min_value")
  maxValue      Float?   @map("max_value")
  initialValue  String?  @map("initial_value") @db.VarChar(200)
  currentValue  String?  @map("current_value") @db.VarChar(200)
  simPattern    String?  @map("sim_pattern") @db.VarChar(20) // sine, random, ramp, square
  simFrequency  Float?   @map("sim_frequency")
  simAmplitude  Float?   @map("sim_amplitude")
  simOffset     Float?   @map("sim_offset")
  formula       String?  @db.Text // for calculated tags
  group         String?  @db.VarChar(100) // folder/group name
  metadata      Json?    @db.JsonB
  projectId     String   @map("project_id") @db.Uuid
  // External device mapping
  deviceId      String?  @map("device_id") @db.Uuid
  addressType   String?  @map("address_type") @db.VarChar(30) // COIL, DISCRETE_INPUT, HOLDING_REGISTER, INPUT_REGISTER, NODE_ID, etc.
  address       String?  @db.VarChar(200)
  byteOrder     String?  @map("byte_order") @db.VarChar(10) // BIG_ENDIAN, LITTLE_ENDIAN, MID_BIG, MID_LITTLE
  wordCount     Int?     @map("word_count")
  bitIndex      Int?     @map("bit_index")
  scaleFactor   Float?   @map("scale_factor")
  scaleOffset   Float?   @map("scale_offset")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  project       Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  device        ExternalDevice?  @relation(fields: [deviceId], references: [id], onDelete: SetNull)

  @@unique([projectId, name])
  @@map("tags")
}

model TagScript {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(200)
  code      String   @db.Text
  category  String?  @db.VarChar(50)
  projectId String   @map("project_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("tag_scripts")
}

model TestScenario {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(200)
  steps     Json     @default("[]") @db.JsonB // array of {delay, tagName, value}
  projectId String   @map("project_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("test_scenarios")
}

// ─── AI Analytics ─────────────────────────────────

model TagHistory {
  id        String   @id @default(uuid()) @db.Uuid
  tagId     String   @map("tag_id") @db.Uuid
  tagName   String   @map("tag_name") @db.VarChar(200)
  value     Float
  timestamp DateTime @db.Timestamptz()
  quality   String?  @db.VarChar(20) // GOOD, BAD, UNCERTAIN

  @@index([tagName, timestamp])
  @@map("tag_history")
}

model AIPrediction {
  id             String   @id @default(uuid()) @db.Uuid
  projectId      String   @map("project_id") @db.Uuid
  predictionType String   @map("prediction_type") @db.VarChar(50) // load_forecast, equipment_failure, maintenance
  targetEntity   String?  @map("target_entity") @db.VarChar(200)
  predictedAt    DateTime @map("predicted_at") @db.Timestamptz()
  forecastTime   DateTime @map("forecast_time") @db.Timestamptz()
  predictedValue Float?   @map("predicted_value")
  confidence     Float?
  upperBound     Float?   @map("upper_bound")
  lowerBound     Float?   @map("lower_bound")
  metadata       Json?    @db.JsonB

  @@index([projectId, predictionType])
  @@map("ai_predictions")
}

model EquipmentHealth {
  id            String   @id @default(uuid()) @db.Uuid
  projectId     String   @map("project_id") @db.Uuid
  equipmentName String   @map("equipment_name") @db.VarChar(200)
  equipmentType String   @map("equipment_type") @db.VarChar(50)
  healthScore   Float    @map("health_score")
  status        String   @db.VarChar(20) // healthy, degraded, critical, failed
  anomalies     Json?    @db.JsonB
  predictions   Json?    @db.JsonB
  lastUpdated   DateTime @map("last_updated") @db.Timestamptz()

  @@index([projectId])
  @@map("equipment_health")
}

model AlarmEvent {
  id           String    @id @default(uuid()) @db.Uuid
  projectId    String    @map("project_id") @db.Uuid
  alarmType    String    @map("alarm_type") @db.VarChar(100)
  severity     String    @db.VarChar(20) // info, warning, critical
  source       String    @db.VarChar(200)
  message      String    @db.Text
  timestamp    DateTime  @db.Timestamptz()
  acknowledged Boolean   @default(false)
  clearedAt    DateTime? @map("cleared_at") @db.Timestamptz()
  duration     Int?
  metadata     Json?     @db.JsonB

  @@index([projectId, timestamp])
  @@map("alarm_events")
}

// ─── Control & Audit ───────────────────────────────

model ControlCommand {
  id              String    @id @default(uuid()) @db.Uuid
  equipmentId     String    @map("equipment_id") @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  commandType     String    @map("command_type") @db.VarChar(20)
  sboState        String    @map("sbo_state") @db.VarChar(20)
  initiatedAt     DateTime  @default(now()) @map("initiated_at") @db.Timestamptz()
  completedAt     DateTime? @map("completed_at") @db.Timestamptz()
  resultMessage   String?   @map("result_message")

  equipment       Equipment @relation(fields: [equipmentId], references: [id])
  user            User      @relation(fields: [userId], references: [id])

  @@map("control_commands")
}

model AuditTrail {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String?   @map("user_id") @db.Uuid
  action          String    @db.VarChar(50)
  targetType      String?   @map("target_type") @db.VarChar(50)
  targetId        String?   @map("target_id") @db.Uuid
  details         Json      @default("{}") @db.JsonB
  ipAddress       String?   @map("ip_address") @db.VarChar(45)
  timestamp       DateTime  @default(now()) @db.Timestamptz()

  user            User?     @relation(fields: [userId], references: [id])

  @@map("audit_trail")
}

// ─── Recipes ──────────────────────────────────────

model Recipe {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @db.VarChar(200)
  description String?   @db.Text
  category    String?   @db.VarChar(100)
  steps       Json      @default("[]") @db.JsonB
  isActive    Boolean   @default(false) @map("is_active")
  lastRunAt   DateTime? @map("last_run_at") @db.Timestamptz()
  projectId   String    @map("project_id") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, name])
  @@map("recipes")
}

// ─── Report Templates ─────────────────────────────

model ReportTemplate {
  id              String    @id @default(uuid()) @db.Uuid
  name            String    @db.VarChar(200)
  description     String?   @db.Text
  type            String    @db.VarChar(30)
  schedule        String?   @db.VarChar(50)
  config          Json      @db.JsonB
  lastGeneratedAt DateTime? @map("last_generated_at") @db.Timestamptz()
  projectId       String    @map("project_id") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("report_templates")
}

model GeneratedReport {
  id         String   @id @default(uuid()) @db.Uuid
  templateId String   @map("template_id") @db.Uuid
  name       String   @db.VarChar(200)
  data       Json     @db.JsonB
  format     String   @db.VarChar(10)
  projectId  String   @map("project_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()

  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("generated_reports")
}

// ─── Command Sequencing ───────────────────────────

model CommandSequence {
  id              String   @id @default(uuid()) @db.Uuid
  name            String   @db.VarChar(200)
  description     String?  @db.Text
  category        String?  @db.VarChar(100)
  steps           Json     @default("[]") @db.JsonB
  requiresAuth    Boolean  @default(true) @map("requires_auth")
  authorityLevel  Int      @default(1) @map("authority_level")
  isEmergency     Boolean  @default(false) @map("is_emergency")
  projectId       String   @map("project_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, name])
  @@map("command_sequences")
}

model CommandExecution {
  id            String    @id @default(uuid()) @db.Uuid
  sequenceId    String    @map("sequence_id") @db.Uuid
  sequenceName  String    @map("sequence_name") @db.VarChar(200)
  status        String    @db.VarChar(20)
  currentStep   Int       @default(0) @map("current_step")
  totalSteps    Int       @map("total_steps")
  startedBy     String    @map("started_by") @db.VarChar(200)
  stepResults   Json      @default("[]") @db.JsonB
  errorMessage  String?   @map("error_message") @db.Text
  startedAt     DateTime  @default(now()) @map("started_at") @db.Timestamptz()
  completedAt   DateTime? @map("completed_at") @db.Timestamptz()
  projectId     String    @map("project_id") @db.Uuid

  @@map("command_executions")
}

// ─── Interlocking Logic ───────────────────────────

model Interlock {
  id           String   @id @default(uuid()) @db.Uuid
  name         String   @db.VarChar(200)
  description  String?  @db.Text
  targetTag    String   @map("target_tag") @db.VarChar(200)
  targetAction String   @map("target_action") @db.VarChar(20)
  targetValue  String?  @map("target_value") @db.VarChar(100)
  conditions   Json     @db.JsonB
  enabled      Boolean  @default(true)
  priority     Int      @default(1)
  bypassable   Boolean  @default(false)
  bypassLevel  Int      @default(3) @map("bypass_level")
  projectId    String   @map("project_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("interlocks")
}

model InterlockEvent {
  id            String   @id @default(uuid()) @db.Uuid
  interlockId   String   @map("interlock_id") @db.Uuid
  interlockName String   @map("interlock_name") @db.VarChar(200)
  targetTag     String   @map("target_tag") @db.VarChar(200)
  action        String   @db.VarChar(20)
  attemptedBy   String   @map("attempted_by") @db.VarChar(200)
  conditions    Json     @db.JsonB
  bypassed      Boolean  @default(false)
  bypassedBy    String?  @map("bypassed_by") @db.VarChar(200)
  bypassReason  String?  @map("bypass_reason") @db.Text
  projectId     String   @map("project_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@map("interlock_events")
}

// ─── Select-Before-Operate ────────────────────────

model SBOConfig {
  id              String   @id @default(uuid()) @db.Uuid
  tagName         String   @map("tag_name") @db.VarChar(200)
  enabled         Boolean  @default(true)
  selectTimeout   Int      @default(30) @map("select_timeout")
  confirmRequired Boolean  @default(true) @map("confirm_required")
  authorityLevel  Int      @default(1) @map("authority_level")
  projectId       String   @map("project_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()

  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, tagName])
  @@map("sbo_configs")
}

// ─── Authority Levels ─────────────────────────────

model OperatorAuthority {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  userName    String    @map("user_name") @db.VarChar(200)
  level       Int
  permissions Json      @default("[]") @db.JsonB
  zones       Json      @default("[]") @db.JsonB
  activeFrom  DateTime? @map("active_from") @db.Timestamptz()
  activeTo    DateTime? @map("active_to") @db.Timestamptz()
  isActive    Boolean   @default(true) @map("is_active")
  projectId   String    @map("project_id") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("operator_authorities")
}
