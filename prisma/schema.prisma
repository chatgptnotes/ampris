generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Substations ───────────────────────────────────

model Substation {
  id              String    @id @default(uuid()) @db.Uuid
  name            String    @db.VarChar(100)
  code            String    @unique @db.VarChar(20)
  type            String    @db.VarChar(20) // '33/11kV' | '132/33kV'
  location        String?   @db.VarChar(200)
  latitude        Decimal?  @db.Decimal(10, 7)
  longitude       Decimal?  @db.Decimal(10, 7)
  commissionedAt  DateTime? @map("commissioned_at") @db.Date
  status          String    @default("ACTIVE") @db.VarChar(20)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  voltageLevels   VoltageLevel[]
  iedConnections  IedConnection[]

  @@map("substations")
}

model VoltageLevel {
  id              String    @id @default(uuid()) @db.Uuid
  substationId    String    @map("substation_id") @db.Uuid
  nominalKv       Decimal   @map("nominal_kv") @db.Decimal(6, 1)
  levelType       String    @map("level_type") @db.VarChar(10) // 'HV' | 'LV' | 'TV'
  busConfig       String    @default("SINGLE_BUS") @map("bus_config") @db.VarChar(30)

  substation      Substation @relation(fields: [substationId], references: [id])
  bays            Bay[]

  @@map("voltage_levels")
}

model Bay {
  id              String    @id @default(uuid()) @db.Uuid
  voltageLevelId  String    @map("voltage_level_id") @db.Uuid
  name            String    @db.VarChar(50)
  bayType         String    @map("bay_type") @db.VarChar(20)
  bayNumber       Int?      @map("bay_number")
  status          String    @default("ACTIVE") @db.VarChar(20)

  voltageLevel    VoltageLevel @relation(fields: [voltageLevelId], references: [id])
  equipment       Equipment[]

  @@map("bays")
}

model Equipment {
  id              String    @id @default(uuid()) @db.Uuid
  bayId           String    @map("bay_id") @db.Uuid
  type            String    @db.VarChar(30)
  tag             String    @unique @db.VarChar(80)
  name            String    @db.VarChar(100)
  ratedVoltage    Decimal?  @map("rated_voltage") @db.Decimal(8, 2)
  ratedCurrent    Decimal?  @map("rated_current") @db.Decimal(8, 2)
  ratedMva        Decimal?  @map("rated_mva") @db.Decimal(8, 2)
  sldX            Int       @default(0) @map("sld_x")
  sldY            Int       @default(0) @map("sld_y")
  sldRotation     Int       @default(0) @map("sld_rotation")
  metadata        Json      @default("{}") @db.JsonB

  bay             Bay       @relation(fields: [bayId], references: [id])
  dataPoints      DataPoint[]
  controlCommands ControlCommand[]

  @@map("equipment")
}

model DataPoint {
  id              String    @id @default(uuid()) @db.Uuid
  equipmentId     String    @map("equipment_id") @db.Uuid
  tag             String    @unique @db.VarChar(100)
  name            String    @db.VarChar(150)
  paramType       String    @map("param_type") @db.VarChar(10) // 'ANALOG' | 'DIGITAL' | 'COUNTER'
  unit            String?   @db.VarChar(20)
  minValue        Decimal?  @map("min_value") @db.Decimal(12, 4)
  maxValue        Decimal?  @map("max_value") @db.Decimal(12, 4)
  deadband        Decimal   @default(0) @db.Decimal(8, 4)
  iedConnectionId String?   @map("ied_connection_id") @db.Uuid
  registerAddress Int?      @map("register_address")
  registerType    String?   @map("register_type") @db.VarChar(20)
  scaleFactor     Decimal   @default(1.0) @map("scale_factor") @db.Decimal(10, 6)
  offsetValue     Decimal   @default(0) @map("offset_value") @db.Decimal(10, 4)

  equipment       Equipment @relation(fields: [equipmentId], references: [id])
  iedConnection   IedConnection? @relation(fields: [iedConnectionId], references: [id])
  alarmDefinitions AlarmDefinition[]

  @@map("data_points")
}

model IedConnection {
  id              String    @id @default(uuid()) @db.Uuid
  substationId    String    @map("substation_id") @db.Uuid
  name            String    @db.VarChar(100)
  protocol        String    @db.VarChar(20) // 'MODBUS_TCP' | 'DNP3' | 'IEC61850'
  ipAddress       String    @map("ip_address") @db.VarChar(45)
  port            Int
  slaveId         Int?      @map("slave_id")
  pollingIntervalMs Int     @default(1000) @map("polling_interval_ms")
  timeoutMs       Int       @default(5000) @map("timeout_ms")
  status          String    @default("ACTIVE") @db.VarChar(20)

  substation      Substation @relation(fields: [substationId], references: [id])
  dataPoints      DataPoint[]

  @@map("ied_connections")
}

// ─── Users & Auth ──────────────────────────────────

model User {
  id              String    @id @default(uuid()) @db.Uuid
  username        String    @unique @db.VarChar(50)
  passwordHash    String    @map("password_hash") @db.VarChar(255)
  name            String    @db.VarChar(100)
  email           String?   @db.VarChar(100)
  role            String    @db.VarChar(20) // 'ADMIN' | 'ENGINEER' | 'OPERATOR' | 'VIEWER'
  isActive        Boolean   @default(true) @map("is_active")
  lastLogin       DateTime? @map("last_login") @db.Timestamptz()
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  sessions            Session[]
  alarmAcks           AlarmLog[] @relation("alarm_acked_by")
  controlCommands     ControlCommand[]
  auditTrail          AuditTrail[]
  projects            Project[]
  projectMemberships  ProjectMember[]

  @@map("users")
}

model Session {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  tokenHash       String    @map("token_hash") @db.VarChar(255)
  ipAddress       String?   @map("ip_address") @db.VarChar(45)
  userAgent       String?   @map("user_agent")
  expiresAt       DateTime  @map("expires_at") @db.Timestamptz()
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  user            User      @relation(fields: [userId], references: [id])

  @@map("sessions")
}

// ─── Alarms ────────────────────────────────────────

model AlarmDefinition {
  id              String    @id @default(uuid()) @db.Uuid
  dataPointId     String    @map("data_point_id") @db.Uuid
  alarmType       String    @map("alarm_type") @db.VarChar(20)
  threshold       Decimal?  @db.Decimal(12, 4)
  priority        Int       @db.SmallInt
  messageTemplate String    @map("message_template") @db.VarChar(200)
  deadband        Decimal   @default(0) @db.Decimal(8, 4)
  delayMs         Int       @default(0) @map("delay_ms")
  isEnabled       Boolean   @default(true) @map("is_enabled")

  dataPoint       DataPoint @relation(fields: [dataPointId], references: [id])
  alarmLogs       AlarmLog[]

  @@map("alarm_definitions")
}

model AlarmLog {
  id              String    @id @default(uuid()) @db.Uuid
  alarmDefId      String    @map("alarm_def_id") @db.Uuid
  raisedAt        DateTime  @default(now()) @map("raised_at") @db.Timestamptz()
  clearedAt       DateTime? @map("cleared_at") @db.Timestamptz()
  ackedAt         DateTime? @map("acked_at") @db.Timestamptz()
  ackedBy         String?   @map("acked_by") @db.Uuid
  shelvedUntil    DateTime? @map("shelved_until") @db.Timestamptz()
  valueAtRaise    Float?    @map("value_at_raise")
  priority        Int       @db.SmallInt
  message         String    @db.VarChar(300)

  alarmDef        AlarmDefinition @relation(fields: [alarmDefId], references: [id])
  ackedByUser     User?     @relation("alarm_acked_by", fields: [ackedBy], references: [id])

  @@map("alarm_log")
}

// ─── Projects & Mimic Pages ──────────────────────────

model Project {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(200)
  description String?  @db.Text
  ownerId     String   @map("owner_id") @db.Uuid
  status      String   @default("ACTIVE") @db.VarChar(20)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  owner       User     @relation(fields: [ownerId], references: [id])
  mimicPages  MimicPage[]
  members     ProjectMember[]
  tags        Tag[]
  tagScripts  TagScript[]
  testScenarios TestScenario[]

  @@map("projects")
}

model MimicPage {
  id              String   @id @default(uuid()) @db.Uuid
  projectId       String   @map("project_id") @db.Uuid
  name            String   @db.VarChar(100)
  pageOrder       Int      @default(0) @map("page_order")
  width           Int      @default(1920)
  height          Int      @default(1080)
  backgroundColor String   @default("#FFFFFF") @map("background_color") @db.VarChar(20)
  gridSize        Int      @default(20) @map("grid_size")
  elements        Json     @default("[]")
  connections     Json     @default("[]")
  isHomePage      Boolean  @default(false) @map("is_home_page")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("mimic_pages")
}

model ProjectMember {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  role      String   @default("VIEWER") @db.VarChar(20)
  assignedAt DateTime @default(now()) @map("assigned_at") @db.Timestamptz()

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_members")
}

// ─── Tags & Testing ───────────────────────────────

model Tag {
  id            String   @id @default(uuid()) @db.Uuid
  name          String   @db.VarChar(200)
  description   String?  @db.Text
  type          String   @db.VarChar(20) // INTERNAL, SIMULATED, CALCULATED, EXTERNAL
  dataType      String   @map("data_type") @db.VarChar(20) // BOOLEAN, INTEGER, FLOAT, STRING
  unit          String?  @db.VarChar(30)
  minValue      Float?   @map("min_value")
  maxValue      Float?   @map("max_value")
  initialValue  String?  @map("initial_value") @db.VarChar(200)
  currentValue  String?  @map("current_value") @db.VarChar(200)
  simPattern    String?  @map("sim_pattern") @db.VarChar(20) // sine, random, ramp, square
  simFrequency  Float?   @map("sim_frequency")
  simAmplitude  Float?   @map("sim_amplitude")
  simOffset     Float?   @map("sim_offset")
  formula       String?  @db.Text // for calculated tags
  group         String?  @db.VarChar(100) // folder/group name
  metadata      Json?    @db.JsonB
  projectId     String   @map("project_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, name])
  @@map("tags")
}

model TagScript {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(200)
  code      String   @db.Text
  category  String?  @db.VarChar(50)
  projectId String   @map("project_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("tag_scripts")
}

model TestScenario {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(200)
  steps     Json     @default("[]") @db.JsonB // array of {delay, tagName, value}
  projectId String   @map("project_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("test_scenarios")
}

// ─── AI Analytics ─────────────────────────────────

model TagHistory {
  id        String   @id @default(uuid()) @db.Uuid
  tagId     String   @map("tag_id") @db.Uuid
  tagName   String   @map("tag_name") @db.VarChar(200)
  value     Float
  timestamp DateTime @db.Timestamptz()
  quality   String?  @db.VarChar(20) // GOOD, BAD, UNCERTAIN

  @@index([tagName, timestamp])
  @@map("tag_history")
}

model AIPrediction {
  id             String   @id @default(uuid()) @db.Uuid
  projectId      String   @map("project_id") @db.Uuid
  predictionType String   @map("prediction_type") @db.VarChar(50) // load_forecast, equipment_failure, maintenance
  targetEntity   String?  @map("target_entity") @db.VarChar(200)
  predictedAt    DateTime @map("predicted_at") @db.Timestamptz()
  forecastTime   DateTime @map("forecast_time") @db.Timestamptz()
  predictedValue Float?   @map("predicted_value")
  confidence     Float?
  upperBound     Float?   @map("upper_bound")
  lowerBound     Float?   @map("lower_bound")
  metadata       Json?    @db.JsonB

  @@index([projectId, predictionType])
  @@map("ai_predictions")
}

model EquipmentHealth {
  id            String   @id @default(uuid()) @db.Uuid
  projectId     String   @map("project_id") @db.Uuid
  equipmentName String   @map("equipment_name") @db.VarChar(200)
  equipmentType String   @map("equipment_type") @db.VarChar(50)
  healthScore   Float    @map("health_score")
  status        String   @db.VarChar(20) // healthy, degraded, critical, failed
  anomalies     Json?    @db.JsonB
  predictions   Json?    @db.JsonB
  lastUpdated   DateTime @map("last_updated") @db.Timestamptz()

  @@index([projectId])
  @@map("equipment_health")
}

model AlarmEvent {
  id           String    @id @default(uuid()) @db.Uuid
  projectId    String    @map("project_id") @db.Uuid
  alarmType    String    @map("alarm_type") @db.VarChar(100)
  severity     String    @db.VarChar(20) // info, warning, critical
  source       String    @db.VarChar(200)
  message      String    @db.Text
  timestamp    DateTime  @db.Timestamptz()
  acknowledged Boolean   @default(false)
  clearedAt    DateTime? @map("cleared_at") @db.Timestamptz()
  duration     Int?
  metadata     Json?     @db.JsonB

  @@index([projectId, timestamp])
  @@map("alarm_events")
}

// ─── Control & Audit ───────────────────────────────

model ControlCommand {
  id              String    @id @default(uuid()) @db.Uuid
  equipmentId     String    @map("equipment_id") @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  commandType     String    @map("command_type") @db.VarChar(20)
  sboState        String    @map("sbo_state") @db.VarChar(20)
  initiatedAt     DateTime  @default(now()) @map("initiated_at") @db.Timestamptz()
  completedAt     DateTime? @map("completed_at") @db.Timestamptz()
  resultMessage   String?   @map("result_message")

  equipment       Equipment @relation(fields: [equipmentId], references: [id])
  user            User      @relation(fields: [userId], references: [id])

  @@map("control_commands")
}

model AuditTrail {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String?   @map("user_id") @db.Uuid
  action          String    @db.VarChar(50)
  targetType      String?   @map("target_type") @db.VarChar(50)
  targetId        String?   @map("target_id") @db.Uuid
  details         Json      @default("{}") @db.JsonB
  ipAddress       String?   @map("ip_address") @db.VarChar(45)
  timestamp       DateTime  @default(now()) @db.Timestamptz()

  user            User?     @relation(fields: [userId], references: [id])

  @@map("audit_trail")
}
